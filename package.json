{
  "name": "microdent-modern",
  "private": true,
  "workspaces": [
    "packages/*",
    "services/*",
    "apps/*"
  ],
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "test": "npm run build --workspace=@microdent/contracts && npm run test --workspace=@microdent/contracts && npm run build --workspace=@microdent/bridge && npm run build --workspace=@microdent/sqlite-mirror && npm run test --workspace=@microdent/sqlite-mirror && npm run test --workspace=@microdent/bridge && npm run build --workspace=@microdent/bridge-client && npm run test --workspace=@microdent/bridge-client && npm run build --workspace=@microdent/ui && npm run test --workspace=@microdent/ui && npm run build --workspace=@microdent/app && npm run test --workspace=@microdent/app && npm run build --workspace=@microdent/desktop && npm run test --workspace=@microdent/desktop",
    "preview:web": "pnpm --filter @microdent/web run dev",
    "build:web": "pnpm --filter @microdent/web run build",
    "dev:ports": "bash scripts/dev-ports.sh",
    "dev:kill-ports": "bash scripts/dev-kill-ports.sh",
    "dev:bridge": "bash scripts/dev-bridge.sh",
    "dev:web": "bash scripts/dev-web.sh",
    "mirror:import-safe": "bash scripts/mirror-import-safe.sh",
    "legacy:backup": "bash scripts/legacy-backup.sh",
    "legacy:create-sandbox": "bash scripts/legacy-create-sandbox.sh",
    "legacy:restore": "bash scripts/legacy-restore.sh",
    "legacy:backup-verify": "bash scripts/legacy-backup-verify.sh",
    "sandbox:validate": "pnpm --filter @microdent/bridge exec vitest run src/sandbox/sandbox-validation-band.test.ts",
    "sandbox:validate:real": "SANDBOX_VALIDATE_REAL=1 pnpm sandbox:validate",
    "qa:sandbox": "bash scripts/qa-sandbox-run.sh",
    "desktop:release-smoke": "pnpm --filter @microdent/desktop run release-smoke",
    "pilot-checkpoint": "pnpm test && pnpm build:web && pnpm desktop:release-smoke",
    "pilot:full-checkpoint": "bash scripts/pilot-full-checkpoint.sh",
    "pilot:distribution-checkpoint": "bash scripts/pilot-distribution-checkpoint.sh",
    "stage:pilot-release": "node scripts/stage-pilot-release.mjs",
    "pilot:stage-release": "pnpm stage:pilot-release",
    "pilot:verify-release": "node scripts/verify-pilot-release.mjs",
    "pilot:verify-manifest": "node scripts/verify-pilot-manifest.mjs",
    "pilot:release-signoff": "bash scripts/pilot-release-signoff.sh",
    "pilot:release-check": "bash scripts/pilot-release-check.sh",
    "pilot:mac-release-status": "node scripts/pilot-mac-release-status.mjs",
    "test:pilot-artifacts": "vitest run scripts/pilot-release-artifacts.test.mjs"
  },
  "engines": {
    "node": ">=18"
  }
}
