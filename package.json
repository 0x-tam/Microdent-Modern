{
  "name": "microdent-modern",
  "private": true,
  "workspaces": [
    "packages/*",
    "services/*",
    "apps/*"
  ],
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "test": "npm run build --workspace=@microdent/contracts && npm run test --workspace=@microdent/contracts && npm run build --workspace=@microdent/bridge && npm run build --workspace=@microdent/sqlite-mirror && npm run test --workspace=@microdent/sqlite-mirror && npm run test --workspace=@microdent/bridge && npm run build --workspace=@microdent/bridge-client && npm run test --workspace=@microdent/bridge-client && npm run build --workspace=@microdent/ui && npm run test --workspace=@microdent/ui && npm run build --workspace=@microdent/app && npm run test --workspace=@microdent/app && npm run build --workspace=@microdent/desktop && npm run test --workspace=@microdent/desktop",
    "preview:web": "pnpm --filter @microdent/web run dev",
    "build:web": "pnpm --filter @microdent/web run build",
    "build:desktop": "pnpm build:web && pnpm --filter @microdent/desktop run build",
    "dev:ports": "bash scripts/dev-ports.sh",
    "dev:kill-ports": "bash scripts/dev-kill-ports.sh",
    "dev:bridge": "bash scripts/dev-bridge.sh",
    "dev:web": "bash scripts/dev-web.sh",
    "mirror:import-safe": "node scripts/mirror-import-safe.mjs",
    "mirror:import-safe:bash": "bash scripts/mirror-import-safe.sh",
    "legacy:backup": "node scripts/legacy-command.mjs backup",
    "legacy:backup:bash": "bash scripts/legacy-backup.sh",
    "legacy:create-sandbox": "node scripts/legacy-command.mjs create-sandbox",
    "legacy:create-sandbox:bash": "bash scripts/legacy-create-sandbox.sh",
    "legacy:restore": "node scripts/legacy-command.mjs restore",
    "legacy:restore:bash": "bash scripts/legacy-restore.sh",
    "legacy:backup-verify": "node scripts/legacy-command.mjs backup-verify",
    "legacy:backup-verify:bash": "bash scripts/legacy-backup-verify.sh",
    "sandbox:validate": "pnpm --filter @microdent/bridge exec vitest run src/sandbox/sandbox-validation-band.test.ts",
    "sandbox:validate:real": "SANDBOX_VALIDATE_REAL=1 pnpm sandbox:validate",
    "qa:sandbox": "node scripts/qa-sandbox-run.mjs",
    "qa:sandbox:bash": "bash scripts/qa-sandbox-run.sh",
    "desktop:release-smoke": "pnpm --filter @microdent/desktop run release-smoke",
    "microdent:oneclick": "node scripts/microdent-oneclick.mjs",
    "microdent:oneclick:quick": "node scripts/microdent-oneclick.mjs --quick",
    "microdent:oneclick:windows": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/windows-oneclick-check.ps1",
    "pilot-checkpoint": "pnpm test && pnpm build:web && pnpm desktop:release-smoke",
    "pilot:full-checkpoint": "node scripts/pilot-checkpoint.mjs full-checkpoint",
    "pilot:full-checkpoint:bash": "bash scripts/pilot-full-checkpoint.sh",
    "pilot:distribution-checkpoint": "node scripts/pilot-checkpoint.mjs distribution-checkpoint",
    "pilot:distribution-checkpoint:bash": "bash scripts/pilot-distribution-checkpoint.sh",
    "stage:pilot-release": "node scripts/stage-pilot-release.mjs",
    "pilot:node-runtime-check": "node scripts/node-runtime-staging.mjs",
    "pilot:stage-release": "pnpm stage:pilot-release",
    "pilot:verify-release": "node scripts/verify-pilot-release.mjs",
    "pilot:verify-manifest": "node scripts/verify-pilot-manifest.mjs",
    "pilot:staged-link-audit": "node scripts/staged-markdown-link-audit.mjs",
    "pilot:package-verify-packet": "node scripts/package-verify-packet.mjs",
    "pilot:package-verify-evidence": "node scripts/package-verify-evidence.mjs",
    "pilot:windows-field-packet": "node scripts/windows-field-packet.mjs",
    "pilot:field-evidence": "node scripts/windows-field-evidence.mjs",
    "pilot:intake-safe-results": "node scripts/intake-safe-results.mjs",
    "pilot:windows-compatibility": "node scripts/windows-compatibility-evidence.mjs",
    "pilot:signed-artifacts": "node scripts/signed-artifact-evidence.mjs",
    "pilot:installer-packet": "node scripts/installer-readiness-packet.mjs",
    "pilot:installer-evidence": "node scripts/installer-evidence.mjs",
    "pilot:auto-update-packet": "node scripts/auto-update-readiness-packet.mjs",
    "pilot:auto-update-evidence": "node scripts/auto-update-evidence.mjs",
    "pilot:clinic-report": "node scripts/clinic-pilot-report-evidence.mjs",
    "pilot:commercial-launch-packet": "node scripts/commercial-launch-packet.mjs",
    "pilot:support-readiness": "node scripts/support-readiness-evidence.mjs",
    "pilot:distribution-evidence": "node scripts/distribution-evidence.mjs",
    "pilot:pricing-evidence": "node scripts/pricing-evidence.mjs",
    "pilot:marketing-evidence": "node scripts/marketing-evidence.mjs",
    "pilot:go-live-packet": "node scripts/go-live-readiness-packet.mjs",
    "pilot:go-live-evidence": "node scripts/go-live-evidence.mjs",
    "license:validate": "node scripts/offline-license-validate.mjs",
    "pilot:attachment-manifest": "node scripts/evidence-attachment-manifest.mjs",
    "pilot:evidence-repo-guard": "node scripts/evidence-repo-guard.mjs",
    "pilot:evidence-collection-packet": "node scripts/evidence-collection-packet.mjs",
    "pilot:evidence-filing-plan": "node scripts/evidence-filing-plan.mjs",
    "pilot:commercial-evidence-status": "node scripts/commercial-evidence-status.mjs",
    "pilot:commercial-readiness": "node scripts/commercial-readiness-audit.mjs",
    "roadmap:completion-audit": "node scripts/roadmap-completion-audit.mjs",
    "roadmap:local-audit": "node scripts/roadmap-local-audit.mjs",
    "roadmap:local-audit:bash": "bash scripts/roadmap-local-audit.sh",
    "pilot:release-signoff": "node scripts/pilot-release-signoff.mjs",
    "pilot:release-signoff:bash": "bash scripts/pilot-release-signoff.sh",
    "pilot:release-check": "node scripts/pilot-checkpoint.mjs release-check",
    "pilot:release-check:bash": "bash scripts/pilot-release-check.sh",
    "pilot:mac-release-status": "node scripts/pilot-mac-release-status.mjs",
    "test:pilot-artifacts": "node --test scripts/pilot-release-artifacts.test.mjs",
    "strict-signoff:prepare": "node scripts/prepare-strict-signoff-sandbox.mjs",
    "strict-signoff:local": "node scripts/strict-signoff-local.mjs",
    "strict-signoff:local:bash": "bash scripts/strict-signoff-local.sh",
    "perf:synthetic": "corepack pnpm --dir services/bridge exec tsx ../../scripts/synthetic-performance-profile.ts"
  },
  "engines": {
    "node": ">=18"
  }
}
