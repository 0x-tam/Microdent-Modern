*.log
.env
.env.*
# Tracked template for web preview bridge URL (see apps/web/README.md)
!apps/web/.env.local.example

# OS / editor
.DS_Store
Thumbs.db

# -----------------------------------------------------------------------------
# Legacy Microdent / FoxPro — hygiene (PHI, supply chain, accidental commits)
# -----------------------------------------------------------------------------
# Real clinic DATA, legacy application trees, and FoxPro/VB binaries must NEVER
# be committed. They can contain PHI, are not reviewable source, and widen
# supply-chain risk. Keep production or clinic copies outside this repo; for
# local read-only bridge checks, use an absolute DATA_ROOT to a copied folder
# on disk — never paste real DATA into the working tree for git to pick up.
#
# Exception: the single synthetic DBF below is the only .dbf that belongs in git.

# If legacy folders are symlinked or copied under the repo root, ignore them:
/Microdent-Legacy/
/Microdent-Legacy-Copy/
/DATA/
/DATA old/
/DATA ORIG/

# Real legacy / FoxPro-related extensions (case variants for cross-platform clones)
*.dbf
*.DBF
*.fpt
*.FPT
*.cdx
*.CDX
*.dbc
*.DBC
*.dct
*.DCT
*.dcx
*.DCX
*.exe
*.EXE
*.dll
*.DLL
*.ocx
*.OCX
*.vbx
*.VBX
*.rpt
*.RPT
*.frx
*.FRX
*.frt
*.FRT

# Local SQLite mirrors (operator paths outside git; ignore if copied in-tree)
*.sqlite
*.sqlite3
*.db

# Timestamped DBF sidecar backups (BACKUP_DIR / operator sandbox)
backups/
**/backups/

# Disposable write sandbox trees (never commit clinic DATA copies)
Microdent-Write-Sandbox/
**/Microdent-Write-Sandbox/

# Synthetic fixture used by bridge tests — must remain tracked
!services/bridge/fixtures/sandbox/FAKE_TINY.dbf
